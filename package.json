{
  "name": "longer-agent",
  "version": "0.1.3",
  "updateNotice": "",
  "description": "A terminal AI coding agent built for long sessions — three-layer context management, persistent memory, and parallel sub-agents",
  "type": "module",
  "license": "MIT",
  "author": "Felix Rui Gao",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/FelixRuiGao/LongerAgent.git"
  },
  "homepage": "https://github.com/FelixRuiGao/LongerAgent",
  "bugs": {
    "url": "https://github.com/FelixRuiGao/LongerAgent/issues"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "longeragent": "dist/cli.js"
  },
  "files": [
    "dist/",
    "agent_templates/",
    "prompts/",
    "skills/",
    "LICENSE",
    "README.md"
  ],
  "keywords": [
    "ai",
    "agent",
    "cli",
    "llm",
    "coding-agent",
    "multi-agent",
    "context-management",
    "summarization",
    "terminal"
  ],
  "scripts": {
    "docs:dev": "vitepress dev docs-site",
    "docs:build": "vitepress build docs-site",
    "docs:preview": "vitepress preview docs-site",
    "build": "node -e \"const fs=require('fs');fs.rmSync('dist',{recursive:true,force:true});\" && tsc -p tsconfig.build.json && chmod +x dist/cli.js",
    "dev": "tsx src/cli.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "pnpm build && pnpm test",
    "gui:install": "cd gui && pnpm install",
    "gui:build": "cd gui && pnpm build",
    "gui:dev": "cd gui && pnpm dev",
    "gui:start": "cd gui && pnpm start"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.61.0",
    "@inquirer/prompts": "^8.3.0",
    "commander": "^12.0.0",
    "gpt-tokenizer": "^3.4.0",
    "ink": "^6.8.0",
    "js-yaml": "^4.1.0",
    "marked": "^15.0.0",
    "marked-terminal": "^7.0.0",
    "markitdown-ts": "^0.0.10",
    "openai": "^4.90.0",
    "react": "^19.2.4"
  },
  "devDependencies": {
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^22.0.0",
    "@types/react": "^19.2.14",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0",
    "vitepress": "^1.6.4",
    "vitest": "^3.0.0"
  },
  "optionalDependencies": {
    "@modelcontextprotocol/sdk": "^1.12.0"
  }
}
