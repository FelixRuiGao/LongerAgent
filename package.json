{
  "name": "vigil-code",
  "version": "0.2.0",
  "updateNotice": "",
  "description": "A terminal AI coding agent built for long sessions — three-layer context management, persistent memory, and parallel sub-agents",
  "type": "module",
  "license": "MIT",
  "author": "Felix Rui Gao",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/FelixRuiGao/Vigil.git"
  },
  "homepage": "https://github.com/FelixRuiGao/Vigil",
  "bugs": {
    "url": "https://github.com/FelixRuiGao/Vigil/issues"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "vigil": "dist/cli.js"
  },
  "files": [
    "dist/",
    "agent_templates/",
    "prompts/",
    "skills/",
    "LICENSE",
    "README.md"
  ],
  "keywords": [
    "ai",
    "agent",
    "cli",
    "llm",
    "coding-agent",
    "multi-agent",
    "context-management",
    "summarization",
    "terminal"
  ],
  "scripts": {
    "build": "node -e \"const fs=require('fs');fs.rmSync('dist',{recursive:true,force:true});\" && tsc -p tsconfig.build.json && chmod +x dist/cli.js",
    "dev": "bun run opentui-src/main.tsx",
    "dev:cli": "tsx src/cli.ts",
    "opentui:dev": "bun run opentui-src/main.tsx",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "pnpm build && pnpm test"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.61.0",
    "@inquirer/prompts": "^8.3.0",
    "@opentui/core": "^0.1.88",
    "@opentui/core-darwin-arm64": "0.1.88",
    "@opentui/react": "^0.1.88",
    "bun-ffi-structs": "^0.1.2",
    "commander": "^12.0.0",
    "diff": "^8.0.3",
    "gpt-tokenizer": "^3.4.0",
    "ink": "^6.8.0",
    "jimp": "^1.6.0",
    "js-yaml": "^4.1.0",
    "marked": "^15.0.0",
    "marked-terminal": "^7.0.0",
    "markitdown-ts": "^0.0.10",
    "openai": "^4.90.0",
    "react": "^19.2.4",
    "shiki": "^4.0.2",
    "string-width": "7.2.0",
    "tree-sitter-bash": "^0.25.1",
    "web-tree-sitter": "^0.26.7",
    "yoga-layout": "^3.2.1"
  },
  "devDependencies": {
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^22.0.0",
    "@types/react": "^19.2.14",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0",
    "vitepress": "^1.6.4",
    "vitest": "^3.0.0"
  },
  "optionalDependencies": {
    "@modelcontextprotocol/sdk": "^1.12.0"
  },
  "pnpm": {
    "overrides": {
      "@opentui/core": "link:./opentui-src/forked/core"
    }
  }
}
