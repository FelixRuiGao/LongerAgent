{
  "name": "fermi-code",
  "version": "0.2.0",
  "updateNotice": "",
  "description": "A terminal AI coding agent built for long sessions — three-layer context management, persistent memory, and parallel sub-agents",
  "type": "module",
  "license": "MIT",
  "author": "Felix Rui Gao",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/FelixRuiGao/Fermi.git"
  },
  "homepage": "https://github.com/FelixRuiGao/Fermi",
  "bugs": {
    "url": "https://github.com/FelixRuiGao/Fermi/issues"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "fermi": "dist/cli.js"
  },
  "workspaces": [
    "opentui-src/forked/core"
  ],
  "files": [
    "dist/",
    "agent_templates/",
    "prompts/",
    "skills/",
    "LICENSE",
    "README.md"
  ],
  "keywords": [
    "ai",
    "agent",
    "cli",
    "llm",
    "coding-agent",
    "multi-agent",
    "context-management",
    "summarization",
    "terminal"
  ],
  "scripts": {
    "build": "rm -rf dist && tsc -p tsconfig.build.json && chmod +x dist/cli.js",
    "dev": "bun run opentui-src/main.tsx",
    "dev:cli": "bun src/cli.ts",
    "opentui:dev": "bun run opentui-src/main.tsx",
    "test": "bun test tests/ opentui-src/transcript/",
    "test:watch": "bun test --watch tests/ opentui-src/transcript/",
    "typecheck": "tsc --noEmit",
    "docs:dev": "bunx vitepress dev docs-site",
    "docs:build": "bunx vitepress build docs-site",
    "prepublishOnly": "bun run build && bun test"
  },
  "engines": {
    "bun": ">=1.3.0"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.61.0",
    "@inquirer/prompts": "^8.3.0",
    "@opentui/core": "workspace:*",
    "@opentui/core-darwin-arm64": "0.1.88",
    "@opentui/react": "^0.1.88",
    "bun-ffi-structs": "^0.1.2",
    "commander": "^12.0.0",
    "diff": "^8.0.3",
    "gpt-tokenizer": "^3.4.0",
    "jimp": "^1.6.0",
    "js-yaml": "^4.1.0",
    "marked": "^15.0.0",
    "marked-terminal": "^7.0.0",
    "markitdown-ts": "^0.0.10",
    "openai": "^4.90.0",
    "react": "^19.2.4",
    "shiki": "^4.0.2",
    "string-width": "7.2.0",
    "tree-sitter-bash": "^0.25.1",
    "web-tree-sitter": "^0.26.7",
    "yoga-layout": "^3.2.1"
  },
  "devDependencies": {
    "@types/bun": "^1.3.0",
    "@types/js-yaml": "^4.0.9",
    "@types/react": "^19.2.14",
    "typescript": "^5.7.0",
    "vitepress": "^1.6.4"
  },
  "optionalDependencies": {
    "@modelcontextprotocol/sdk": "^1.12.0"
  },
  "overrides": {
    "@opentui/core": "workspace:*"
  }
}
