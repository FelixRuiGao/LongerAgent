{
  "name": "longeragent-gui",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "GUI_DEV=1 concurrently -n main,renderer \"node build-main.mjs && electron dist-main/main.js\" \"vite\"",
    "build:main": "node build-main.mjs",
    "build:renderer": "vite build",
    "build": "node build-main.mjs && vite build",
    "start": "electron dist-main/main.js"
  },
  "dependencies": {
    "react": "^19.2.4",
    "react-dom": "^19.2.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": ["electron", "esbuild", "@esbuild/darwin-arm64"]
  },
  "devDependencies": {
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^4.5.2",
    "concurrently": "^9.1.0",
    "electron": "^35.2.1",
    "esbuild": "^0.25.0",
    "typescript": "^5.7.0",
    "vite": "^6.3.5"
  }
}
